---
import "../styles/global.css";

interface Props {
  title: string;
  description?: string;
}

const { title, description = "Institute of Computing Technology, Chinese Academy of Sciences." } = Astro.props;
const canonical = new URL(Astro.url.pathname, Astro.site ?? "https://lynnho.github.io");
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <meta name="description" content={description} />
    <meta name="theme-color" content="#fbfbfc" />
    <link rel="preconnect" href="https://img.shields.io" />
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
      href="https://fonts.googleapis.com/css2?family=Noto+Sans+SC:wght@400;500;600;700&family=Noto+Serif+SC:wght@600;700&family=Source+Sans+3:wght@400;500;600;700;800&family=Source+Serif+4:wght@600;700&display=swap"
      rel="stylesheet"
    />
    <link rel="canonical" href={canonical.href} />
    <link rel="icon" href="/images/favicon.ico" />
    <link rel="manifest" href="/images/manifest.json" />
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:url" content={canonical.href} />
    <meta property="og:type" content="website" />
    <title>{title}</title>
  </head>
  <body>
    <a class="skip-link" href="#main-content">Skip to content</a>
    <slot />
  </body>
</html>
